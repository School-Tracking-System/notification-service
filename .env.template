# Notification Service - Variables de Entorno
# Copiar este archivo como .env y ajustar los valores según el entorno.
# cp .env.template .env

# Nombre del servicio (usado en logs y tracing)
SERVICE_NAME=notification

# Puerto HTTP (healthcheck futuro)
PORT=8085

# Puerto del servidor gRPC Principal
GRPC_PORT=9095

# URL connection to Fleet Service
FLEET_SERVICE_URL=localhost:9090

# URL de conexión a PostgreSQL
# Formato: postgres://<user>:<password>@<host>:<port>/<database>?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/notification_db?sslmode=disable

# URL de conexión a NATS JetStream
NATS_URL=nats://localhost:4222

# Twilio - Proveedor SMS
# Obtener credenciales en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_PHONE=+15551234567

# Firebase Cloud Messaging (FCM) - Proveedor Push
# Ruta al archivo JSON de credenciales de cuenta de servicio de Firebase
# Dejar vacío para usar modo dev (logs en consola en lugar de enviar)
FCM_CREDENTIAL_PATH=/path/to/firebase-credentials.json

# Entorno de ejecución (development | production)
ENVIRONMENT=development

# Nivel de log (debug | info | warn | error)
LOG_LEVEL=debug
